# ============================================================================
# production Service Environment Variables
# ============================================================================
# This file contains example environment variables for the production service.
# Copy this file to .env and fill in actual values.
#
# Naming Convention:
# - production_* = Service-specific resources (dedicated to production)
# - SHARED_* = Resources shared across services
# - Unprefixed = Infrastructure variables
# ============================================================================

# ============================================================================
# Service-Specific Configuration (production_*)
# ============================================================================

# MongoDB Configuration (production-specific database)
production_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
production_MONGODB_DATABASE_NAME=production
production_MONGODB_SSL_VERIFY=false

# AWS S3 Configuration (production-specific bucket for videos/images)
production_AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
production_AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
production_S3_BUCKET_NAME=production-videos
production_AWS_REGION=eu-north-1
production_AWS_ENDPOINT_URL=  # Optional: for S3-compatible services like MinIO
production_S3_USE_PRESIGNED_URL=true
production_S3_PUBLIC_READ=false

# ============================================================================
# Shared Resources (SHARED_*)
# ============================================================================

# PostgreSQL/Supabase Database (Shared across services)
SHARED_DATABASE_URL=postgresql://user:password@host:5432/database

# Supabase Configuration (Shared authentication & storage)
SHARED_SUPABASE_URL=https://xxxxx.supabase.co
SHARED_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SHARED_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SHARED_SUPABASE_JWT_SECRET=your-jwt-secret-here

# AI API Keys (Shared across services)
SHARED_OPENAI_API_KEY=sk-...
SHARED_ANTHROPIC_API_KEY=sk-ant-...
SHARED_GOOGLE_API_KEY=AIza...

# Redis (Shared cache and message broker)
SHARED_REDIS_URL=redis://localhost:6379/0

# Additional API Keys (Shared)
SHARED_API_SECRET_KEY=your-api-secret-key
SHARED_EXTERNAL_SERVICE_API_KEY=external-service-key

# ============================================================================
# Infrastructure Variables (Unprefixed)
# ============================================================================

# Application Environment
ENVIRONMENT=development  # development, staging, production
DEBUG=false
PORT=8001
HOST=0.0.0.0

# AWS Infrastructure (Account-level)
AWS_ACCOUNT_ID=123456789012

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_COLORS=true
LOG_FILE_ENABLED=true
LOG_DIR=/tmp/thea_logs
LOG_MAX_FILE_SIZE=10485760  # 10MB in bytes
LOG_BACKUP_COUNT=5

# Database Pooling
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_RECYCLE=300
DATABASE_POOL_TIMEOUT=10

# CORS Configuration
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080
PRODUCTION_DOMAIN=app.example.com
HTTPS_ENABLED=true

# Rate Limiting
RATE_LIMIT_DEFAULT=1000/hour
RATE_LIMIT_STORAGE_URI=memory://

# Celery Configuration
CELERY_BROKER_URL=${SHARED_REDIS_URL}
CELERY_RESULT_BACKEND=${SHARED_REDIS_URL}

# ============================================================================
# Phase 4 — Post-Production Pipeline
# ============================================================================

# Gemini API (used by all LLM/TTS/video-understanding agents)
GEMINI_API_KEY=AIza...

# Temporary directory for intermediate files (downloaded clips, rendered cuts, WAVs)
# Must have enough disk space for full-length MP4s + WAVs simultaneously
PHASE4_TMP_DIR=/tmp/phase4

# Agent 0 — target output aspect ratio and platforms
PHASE4_TARGET_ASPECT_RATIO=9:16          # e.g. 9:16 for vertical, 16:9 for landscape
PHASE4_TARGET_PLATFORMS=reels,tiktok,shorts

# Agent 5B — TTS voice override
# If set, this voice name is used instead of the one Agent 5A recommends.
# Must be one of the 30 Gemini prebuilt voice names (Kore, Puck, Zephyr, Aoede, etc.)
# Leave blank to let Agent 5A decide automatically.
PHASE4_TTS_VOICE=

# Agent 6 — A/V Merge
# Whether to keep original clip audio as an ambient bed beneath the VO.
# Default: true. Agent 5A decides the volume level (0.0–1.0 float).
# Set to false to mute clip audio entirely (VO becomes sole program audio).
PHASE4_KEEP_CLIP_AUDIO=true

# ============================================================================
# Optional: Backward Compatibility Variables
# ============================================================================
# These are deprecated but supported for backward compatibility
# Prefer using the new SHARED_* or production_* prefixed versions above
# ============================================================================

# Legacy MongoDB
# MONGODB_URI=${production_MONGODB_URI}
# MONGODB_ATLAS_URI=${production_MONGODB_URI}
# MONGODB_DATABASE_NAME=${production_MONGODB_DATABASE_NAME}

# Legacy Database
# DATABASE_URL=${SHARED_DATABASE_URL}

# Legacy Supabase
# SUPABASE_URL=${SHARED_SUPABASE_URL}
# SUPABASE_KEY=${SHARED_SUPABASE_KEY}
# SERVICE_ROLE_KEY=${SHARED_SUPABASE_SERVICE_ROLE_KEY}
# SUPABASE_JWT_SECRET=${SHARED_SUPABASE_JWT_SECRET}

# Legacy AI APIs
# OPENAI_API_KEY=${SHARED_OPENAI_API_KEY}
# ANTHROPIC_API_KEY=${SHARED_ANTHROPIC_API_KEY}
# GOOGLE_API_KEY=${SHARED_GOOGLE_API_KEY}

# Legacy AWS
# AWS_ACCESS_KEY_ID=${production_AWS_ACCESS_KEY_ID}
# AWS_SECRET_ACCESS_KEY=${production_AWS_SECRET_ACCESS_KEY}
# AWS_REGION=${production_AWS_REGION}

# Legacy Redis
# REDIS_URL=${SHARED_REDIS_URL}
